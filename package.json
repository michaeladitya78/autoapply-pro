{
  "name": "autoapply-pro-root",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "npm run dev --workspace=frontend",
    "build": "npm run build --workspace=frontend",
    "start": "npm run start --workspace=frontend",
    "lint": "npm run lint --workspace=frontend",
    "backend:dev": "cd backend && uvicorn app.main:app --reload --host 0.0.0.0 --port 8080",
    "career-ops:install": "cd career-ops && npm install",
    "browser-agent:install": "cd browser-agent && npm install"
  },
  "workspaces": [
    "frontend"
  ]
}
