# ════════════════════════════════════════════════════════════════════════════
#  AutoApply Pro — Root .gitignore
#  NEVER commit real secrets. Use .env.example as the safe template.
# ════════════════════════════════════════════════════════════════════════════

# ─── Environment / Secrets ───────────────────────────────────────────────────
.env
.env.*
!.env.example          # Allow the safe template
backend/.env
backend/.env.*
!backend/.env.example
frontend/.env
frontend/.env.*
!frontend/.env.example
career-ops/.env
career-ops/.env.*

# ─── Python ──────────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.so
*.egg
*.egg-info/
dist/
build/
.eggs/
.pytest_cache/
.mypy_cache/
.ruff_cache/
*.pyo
*.pyd
.Python

# Virtual environments
backend/venv/
backend/.venv/
venv/
.venv/
env/
.env/

# ─── Node / Next.js / Frontend ───────────────────────────────────────────────
node_modules/
.next/
out/
/build
*.tsbuildinfo
next-env.d.ts
.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*
coverage/

# ─── Docker / Infrastructure ─────────────────────────────────────────────────
*.log
install_pg.log

# ─── IDEs & Editors ──────────────────────────────────────────────────────────
.vscode/settings.json   # May contain user-specific paths
.idea/
*.suo
*.user
*.swp
*.swo

# ─── OS ──────────────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db
desktop.ini

# ─── Certificates / Keys ─────────────────────────────────────────────────────
*.pem
*.key
*.p12
*.pfx

# ─── Playwright / Test Artifacts ─────────────────────────────────────────────
test-results/
playwright-report/

# ─── Vercel ──────────────────────────────────────────────────────────────────
.vercel

# ─── Career-ops runtime data ─────────────────────────────────────────────────
career-ops/data/applications.md
career-ops/data/pipeline.md
career-ops/data/scan-history.tsv
career-ops/reports/*.md
career-ops/output/*
career-ops/batch/logs/*
career-ops/batch/batch-state.tsv
career-ops/batch/batch-input.tsv
career-ops/batch/tracker-additions/*.tsv
career-ops/jds/*
career-ops/config/profile.yml
career-ops/portals.yml
career-ops/modes/_profile.md
career-ops/.update-dismissed
career-ops/.update-lock
career-ops/bun.lock
career-ops/package-lock.json
career-ops/career-dashboard
